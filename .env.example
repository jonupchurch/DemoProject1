# Pooled connection (PgBouncer) — used by the Prisma Client at runtime.
# On Vercel Postgres this is provided automatically as POSTGRES_PRISMA_URL.
# For local development, point this at your local Postgres instance.
POSTGRES_PRISMA_URL="postgresql://postgres:PASSWORD@localhost:5432/decision_journal_dev"

# Direct (non-pooled) connection — used only by `prisma migrate`.
# On Vercel Postgres this is provided automatically as POSTGRES_URL_NON_POOLING.
# For local development this can be identical to POSTGRES_PRISMA_URL.
POSTGRES_URL_NON_POOLING="postgresql://postgres:PASSWORD@localhost:5432/decision_journal_dev"

# Separate database used only by the integration test suite (tests/integration),
# kept apart from the dev database per research.md so tests never touch dev data.
TEST_DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/decision_journal_test"
