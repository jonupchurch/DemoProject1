generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  Financial
  Career
  Relationships
  Health
  Housing
  Other
}

enum DecisionStatus {
  Pending
  Resolved
}

enum Verdict {
  Right
  Wrong
  Mixed
}

// Auth.js's own model names — NOT the same thing as spec.md's vocabulary. See
// data-model.md's naming note: this `User` is spec.md's "Account" (a person);
// the `Account` model below is spec.md's "Linked Sign-In" (a provider
// connection). Replaces phase 1's placeholder `Owner`.
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  decisions Decision[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Not populated at runtime under the jwt session strategy (research.md §2) —
// required by the PrismaAdapter interface regardless of session strategy.
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Not used by this project (OAuth-only, no email sign-in) — required by the
// PrismaAdapter interface regardless.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Decision {
  id         String         @id @default(uuid())
  ownerId    String
  owner      User           @relation(fields: [ownerId], references: [id])
  title      String
  cost       Decimal?
  risks      String?
  notes      String?
  confidence Int
  category   Category
  reviewDate DateTime       @db.Date
  status     DecisionStatus @default(Pending)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  options    Option[]
  resolution Resolution?

  @@index([ownerId])
  @@index([reviewDate])
  @@index([category])
}

model Option {
  id         String   @id @default(uuid())
  decisionId String
  decision   Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  name       String
  pros       String?
  cons       String?
  sortOrder  Int

  @@index([decisionId])
}

model Resolution {
  id            String   @id @default(uuid())
  decisionId    String   @unique
  decision      Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  verdict       Verdict
  satisfaction  Int
  learnings     String?
  resolvedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
